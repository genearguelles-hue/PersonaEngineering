{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://persona.engineering/schemas/performance_run_event.schema.json",
  "title": "Persona Engineering Performance Run Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_type", "event_id", "run_id", "correlation_id",
    "sequence", "occurred_at", "recorded_at", "initiator", "plan",
    "property_names", "contracts", "status", "ledger"
  ],
  "properties": {
    "schema_version": {"const": "pe.performance.run.event.v1"},
    "event_type": {
      "enum": [
        "performance.run.requested", "performance.run.started",
        "performance.run.completed", "performance.run.failed",
        "performance.run.timed_out", "performance.run.error"
      ]
    },
    "event_id": {"type": "string", "format": "uuid"},
    "run_id": {"type": "string", "pattern": "^[a-f0-9]{8,32}$"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "sequence": {"type": "integer", "minimum": 1, "maximum": 3},
    "occurred_at": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "initiator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component"],
      "properties": {"component": {"type": "string", "minLength": 1}}
    },
    "plan": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*\\.jmx$"
    },
    "property_names": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]{0,127}$"}
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mcp", "executor", "evidence"],
      "properties": {
        "mcp": {"const": "pe.jmeter.mcp.v1"},
        "executor": {"const": "pe.jmeter.cli.v1"},
        "evidence": {"const": "pe.jmeter.evidence.v1"}
      }
    },
    "status": {
      "enum": ["requested", "running", "completed", "failed", "timed_out", "error"]
    },
    "executor_timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at_epoch", "finished_at_epoch", "duration_seconds", "return_code"],
      "properties": {
        "started_at_epoch": {"type": ["number", "null"]},
        "finished_at_epoch": {"type": ["number", "null"]},
        "duration_seconds": {"type": ["number", "null"], "minimum": 0},
        "return_code": {"type": ["integer", "null"]}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "schema_version", "run_id", "plan", "status", "generated_at", "artifacts"],
      "properties": {
        "ok": {"type": "boolean"},
        "schema_version": {"const": "pe.jmeter.evidence.v1"},
        "run_id": {"type": "string", "pattern": "^[a-f0-9]{8,32}$"},
        "plan": {"type": "string"},
        "status": {"type": "string"},
        "generated_at": {"type": "string", "format": "date-time"},
        "artifacts": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/artifact"}
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string", "maxLength": 1000}
      }
    },
    "ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous_event_hash", "event_hash"],
      "properties": {
        "previous_event_hash": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          ]
        },
        "event_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "size_bytes", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "exists": {"type": "boolean"},
        "size_bytes": {"type": ["integer", "null"], "minimum": 0},
        "sha256": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"exists": {"const": true}}},
          "then": {
            "properties": {
              "size_bytes": {"type": "integer", "minimum": 0},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"event_type": {"const": "performance.run.requested"}}},
      "then": {"properties": {"sequence": {"const": 1}, "status": {"const": "requested"}}}
    },
    {
      "if": {"properties": {"event_type": {"const": "performance.run.started"}}},
      "then": {"properties": {"sequence": {"const": 2}, "status": {"const": "running"}}}
    },
    {
      "if": {"properties": {"event_type": {"const": "performance.run.completed"}}},
      "then": {
        "required": ["executor_timing", "evidence"],
        "properties": {"sequence": {"const": 3}, "status": {"const": "completed"}}
      }
    },
    {
      "if": {"properties": {"event_type": {"const": "performance.run.failed"}}},
      "then": {"properties": {"sequence": {"const": 3}, "status": {"const": "failed"}}}
    },
    {
      "if": {"properties": {"event_type": {"const": "performance.run.timed_out"}}},
      "then": {"properties": {"sequence": {"const": 3}, "status": {"const": "timed_out"}}}
    },
    {
      "if": {"properties": {"event_type": {"const": "performance.run.error"}}},
      "then": {
        "required": ["error"],
        "properties": {"sequence": {"const": 3}, "status": {"const": "error"}}
      }
    }
  ]
}
