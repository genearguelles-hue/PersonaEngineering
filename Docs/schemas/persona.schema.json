{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona.schema.json",
  "title": "Persona Definition Schema",
  "type": "object",
  "required": [
    "persona_id",
    "name",
    "version",
    "purpose",
    "responsibilities",
    "authority_boundaries",
    "tool_permissions",
    "evidence_requirements",
    "escalation_rules",
    "confidence_thresholds",
    "ledger_obligations"
  ],
  "properties": {
    "persona_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "responsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_boundaries": {
      "type": "object",
      "properties": {
        "may_create_tests": { "type": "boolean" },
        "may_modify_tests": { "type": "boolean" },
        "may_execute_tests": { "type": "boolean" },
        "may_evaluate_ai_outputs": { "type": "boolean" },
        "may_perform_red_team_tests": { "type": "boolean" },
        "may_challenge_decisions": { "type": "boolean" },
        "may_approve_release": { "type": "boolean" },
        "may_override_policy": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "tool_permissions": {
      "type": "object",
      "required": ["permitted_tools", "prohibited_tools"],
      "properties": {
        "permitted_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prohibited_tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "prohibited_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "escalation_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "escalate_to"],
        "properties": {
          "condition": { "type": "string" },
          "escalate_to": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        }
      }
    },
    "confidence_thresholds": {
      "type": "object",
      "required": ["minimum_confidence", "escalation_threshold"],
      "properties": {
        "minimum_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "escalation_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "ledger_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluation_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "retired"]
    }
  },
  "additionalProperties": false
}